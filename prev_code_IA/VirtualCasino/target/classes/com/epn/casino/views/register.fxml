<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.epn.casino.controller.RegisterController"
      stylesheets="/com/epn/casino/styles/casino_premium.css"
      styleClass="main-background" alignment="CENTER" spacing="20" prefWidth="900" prefHeight="600">

    <Label text="NEW PLAYER REGISTRATION" styleClass="title-label"/>
    <Label text="Join the Premium Virtual Casino" styleClass="subtitle-label"/>

    <VBox alignment="CENTER" spacing="15" maxWidth="350">
        <TextField fx:id="txtUsername" promptText="Player Nickname"
                   style="-fx-font-size: 16px; -fx-padding: 10px; -fx-background-radius: 5px;"/>

        <TextField fx:id="txtEmail" promptText="Email Address"
                   style="-fx-font-size: 16px; -fx-padding: 10px; -fx-background-radius: 5px;"/>

        <PasswordField fx:id="txtPassword" promptText="Secure Password"
                       style="-fx-font-size: 16px; -fx-padding: 10px; -fx-background-radius: 5px;"/>

        <TextField fx:id="txtDeposit" promptText="Initial Deposit (Min $10)"
                   style="-fx-font-size: 16px; -fx-padding: 10px; -fx-background-radius: 5px;"/>

        <Label fx:id="lblError" textFill="#ff4c4c" style="-fx-font-weight: bold;"/>

        <Button text="CREATE ACCOUNT" onAction="#handleRegister" styleClass="game-button slots-button" maxWidth="Infinity"/>
        <Button text="Back to Login" onAction="#goBack" styleClass="logout-button"/>
    </VBox>

</VBox>